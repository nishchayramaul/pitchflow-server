APP_NAME=PitchFlow API
FRONTEND_ORIGIN=http://localhost:4200
# Supabase transaction pooler (recommended for local IPv4 + production stability)
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT_REF]:[URL_ENCODED_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Supabase JWT verification for Bearer tokens from frontend
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://[PROJECT_REF].supabase.co/auth/v1
